{
  "name": "supapoker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "cf:deploy": "pnpm build && wrangler --cwd .output deploy",
    "cf:local": "pnpm build && CI=true wrangler d1 migrations apply DB --local --config .output/server/wrangler.json --persist-to .wrangler/state && wrangler dev --config .output/server/wrangler.json --persist-to .wrangler/state --env-file .env --var NUXT_PUBLIC_SITE_URL:http://localhost:8787",
    "cf:preview": "pnpm build && wrangler --cwd .output dev",
    "db:generate": "nuxt db generate",
    "db:migrate": "nuxt db migrate",
    "dev": "pnpm run cf:local",
    "dev:nuxt": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "node --test tests/*.test.ts",
    "typecheck": "nuxi typecheck"
  },
  "dependencies": {
    "@nuxt/ui": "^4.8.2",
    "@nuxthub/core": "^0.10.7",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.1.0",
    "better-auth": "^1.6.22",
    "drizzle-orm": "^0.45.2",
    "image-meta": "^0.2.2",
    "nuxt": "^4.4.8",
    "nuxt-email-renderer": "^2.8.0",
    "vue": "latest",
    "vue-router": "latest",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@iconify-json/lucide": "^1.2.82",
    "@nuxt/hints": "^1.0.0-alpha.4",
    "@types/node": "^26.0.1",
    "drizzle-kit": "^0.31.10",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.107.0"
  },
  "packageManager": "pnpm@11.9.0"
}
