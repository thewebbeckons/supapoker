{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "supapoker",
	"compatibility_date": "2026-06-14",
	"compatibility_flags": ["nodejs_compat"],
	"durable_objects": {
		"bindings": [
			{
				"name": "ROOM_SESSION",
				"class_name": "RoomSession",
			},
		],
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["RoomSession"],
		},
	],
	"send_email": [
		{
			"name": "EMAIL",
			"remote": true,
		},
	],
	"vars": {
		"NUXT_PUBLIC_SITE_URL": "https://supapoker.dev",
		"NUXT_PUBLIC_GITHUB_AUTH_ENABLED": "true",
		"EMAIL_FROM": "SupaPoker <noreply@supapoker.dev>",
	},
	"observability": {
		"logs": {
			"enabled": true,
			"invocation_logs": true,
		},
		"traces": {
			"enabled": true,
		},
	},
}
